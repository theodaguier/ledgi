generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  settings              UserSettings[]
  workspaceMemberships  WorkspaceMember[]
  invitationsSent      WorkspaceInvitation[]  @relation("Inviter")
  transactions  Transaction[]
}

enum WorkspaceType {
  PERSONAL
  COUPLE
  FAMILY
}

model Workspace {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  type            WorkspaceType  @default(PERSONAL)
  defaultCurrency String         @default("EUR")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  members         WorkspaceMember[]
  invitations     WorkspaceInvitation[]
  bankAccounts    BankAccount[]
  transactions     Transaction[]
  importBatches   ImportBatch[]
  categories      Category[]
  rules           CategorizationRule[]
  manualLabels    ManualLabelCategory[]
  apiKeys         ApiKey[]
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

model WorkspaceMember {
  id          String       @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime     @default(now())
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELED
}

model WorkspaceInvitation {
  id          String           @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole    @default(MEMBER)
  status      InvitationStatus @default(PENDING)
  token       String           @unique
  expiresAt   DateTime
  inviterId   String
  createdAt   DateTime        @default(now())
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter     User             @relation("Inviter", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([email])
}

model UserSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  activeWorkspaceId String?
  locale        String   @default("fr-FR")
  timezone      String   @default("Europe/Paris")
  defaultCurrency String @default("EUR")
  weekStartsOn  Int      @default(1)
  avatarProvider String?
  avatarKey     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  providerId           String
  accountId            String
  accessToken          String?
  refreshToken         String?
  idToken              String?
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  password             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  value      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@unique([identifier, value])
}

model BankAccount {
  id            String   @id @default(cuid())
  workspaceId   String
  ownerUserId   String?
  name          String
  type          AccountType @default(CHECKING)
  bankName      String?
  accountNumber String?
  balance       Decimal? @db.Decimal(12, 2)
  currency      String   @default("EUR")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  importBatches ImportBatch[]
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
  OTHER
}

model ImportBatch {
  id             String   @id @default(cuid())
  workspaceId    String
  createdByUserId String
  bankAccountId  String
  fileName       String
  originalName   String?
  formatDetected String?
  status         ImportStatus @default(PENDING)
  totalRows      Int      @default(0)
  importedCount  Int      @default(0)
  skippedCount   Int      @default(0)
  errorCount     Int      @default(0)
  errorLog       Json?
  columnMapping  Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bankAccount    BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Transaction {
  id              String   @id @default(cuid())
  importBatchId   String?
  workspaceId     String
  bankAccountId   String
  ownerUserId     String?
  dateOperation   DateTime
  dateValue       DateTime?
  label           String
  labelNormalized String?
  merchant        String?
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("EUR")
  type            TransactionType
  isAutomatic     Boolean  @default(false)
  categoryId     String?
  categoryManual  String?
  confidence      Float    @default(0)
  hash            String
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  importBatch     ImportBatch?  @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  bankAccount     BankAccount   @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  category        Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerUser       User?        @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([bankAccountId, dateOperation])
  @@index([categoryId])
  @@index([workspaceId, hash])
  @@index([ownerUserId])
  @@unique([workspaceId, hash])
}

enum TransactionType {
  DEBIT
  CREDIT
  TRANSFER
  FEE
}

model Category {
  id          String   @id @default(cuid())
  workspaceId String?
  name        String
  slug        String
  description String?
  color       String?
  icon        String?
  isSystem    Boolean  @default(false)
  isIncome    Boolean  @default(false)
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  rules       CategorizationRule[]
  transactions Transaction[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model CategorizationRule {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  priority    Int      @default(0)
  matchType   MatchType
  pattern     String
  categoryId  String
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isActive, priority])
}

model ManualLabelCategory {
  id              String          @id @default(cuid())
  workspaceId     String
  labelNormalized String
  type            TransactionType
  categoryId      String
  updatedAt       DateTime        @updatedAt
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, labelNormalized, type])
  @@index([workspaceId, type])
}

enum MatchType {
  EXACT
  CONTAINS
  STARTS_WITH
  ENDS_WITH
  REGEX
  KEYWORD
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  name        String
  prefix      String    @default("")
  keyHash     String
  scopes      String[]
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isActive])
  @@index([prefix])
}
